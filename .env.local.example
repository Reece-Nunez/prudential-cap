# Prudential Capital - Environment Variables

# Site URL (for email logos, etc.)
NEXT_PUBLIC_SITE_URL=https://www.prudentialcap.com

# Google reCAPTCHA Enterprise
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_API_KEY=
RECAPTCHA_PROJECT_ID=

# Google Places API (Address Autocomplete)
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# Resend (Email Service)
RESEND_API_KEY=

# Zoho CRM
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Sentry (Error Tracking)
SENTRY_AUTH_TOKEN=
